    <script>
        function switchTab(tabName) {
            // Hide all tabs
            const tabs = document.querySelectorAll('.tab-content');
            tabs.forEach(tab => tab.classList.remove('active'));
            
            // Remove active class from all buttons
            const btns = document.querySelectorAll('.tab-btn');
            btns.forEach(btn => btn.classList.remove('active'));
            
            // Show selected tab
            document.getElementById(tabName).classList.add('active');
            
            // Add active class to clicked button
            event.target.classList.add('active');
        }

        function toggleExpand(sectionId) {
            const section = document.getElementById(sectionId);
            section.classList.toggle('show');
            const btn = event.target;
            btn.textContent = section.classList.contains('show') ? '- 收起詳情' : '+ 展開完整法規要點';
        }

        function calculateROI() {
            const buildingArea = parseFloat(document.getElementById('buildingArea').value);
            const solarCapacity = parseFloat(document.getElementById('solarCapacity').value) || (buildingArea / 20);
            const costPerKw = parseFloat(document.getElementById('costPerKw').value);
            const sunHours = parseFloat(document.getElementById('sunHours').value);
            const feedInRate = parseFloat(document.getElementById('feedInRate').value);
            const govSubsidy = parseFloat(document.getElementById('govSubsidy').value);

            if (!buildingArea || !solarCapacity || !costPerKw || !sunHours || !feedInRate) {
                alert('請填入所有必填項目');
                return;
            }

            // Calculate values
            const totalCost = solarCapacity * costPerKw;
            const netInvestment = totalCost - govSubsidy;
            const annualGeneration = solarCapacity * sunHours;
            const annualRevenue = annualGeneration * feedInRate;
            const paybackYears = (netInvestment / annualRevenue).toFixed(1);
            const totalGeneration20 = annualGeneration * 20 * 0.85; // Assuming 0.85 efficiency factor
            const totalRevenue20 = totalGeneration20 * feedInRate * 0.95; // Accounting for degradation

            // Display results
            const resultBox = document.getElementById('resultBox');
            document.getElementById('totalCost').textContent = `NT$${totalCost.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',')} 元`;
            document.getElementById('netInvestment').textContent = `NT$${netInvestment.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',')} 元`;
            document.getElementById('annualGeneration').textContent = `${annualGeneration.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',')} 度`;
            document.getElementById('annualRevenue').textContent = `NT$${annualRevenue.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',')} 元`;
            document.getElementById('paybackPeriod').textContent = `${paybackYears} 年`;
            document.getElementById('totalGeneration20').textContent = `${totalGeneration20.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',')} 度`;
            document.getElementById('totalRevenue20').textContent = `NT$${totalRevenue20.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',')} 元`;

            resultBox.classList.add('show');
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', function() {
            // 設定預設容量計算
            document.getElementById('buildingArea').addEventListener('change', function() {
                const area = parseFloat(this.value);
                if (area && !document.getElementById('solarCapacity').value) {
                    document.getElementById('solarCapacity').value = Math.max(50, Math.round(area / 20));
                }
            });
        });
    </script>
