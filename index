<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Management Cloud - GeoTracer for IoV8</title>
    <!-- 引入 Tailwind CSS 作為樣式框架 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入 Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- 嚴格的字體大小控制配置 (確保大於 14pt / 18.66px) -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontSize: {
                        // 覆寫所有預設小字體，最小尺寸鎖定為 19px (約 14.25pt)
                        'xs': '19px',
                        'sm': '19px',
                        'base': '19px',
                        'lg': '22px',
                        'xl': '26px',
                        '2xl': '32px',
                        '3xl': '38px',
                        '4xl': '48px',
                    },
                    colors: {
                        brand: {
                            blue: '#4a7bed',
                            dark: '#325bbf',
                            bg1: '#5384eb',
                            bg2: '#3a67d4'
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* 確保全域基礎字體符合要求 */
        html { font-size: 19px; }
        body { font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }
        
        /* 自訂輸入框圖示的顏色與位置調整 */
        .input-icon-right {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            pointer-events: none;
        }
        .input-icon-left {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            pointer-events: none;
        }
    </style>
</head>
<body class="bg-[#f3f4f6] text-gray-800 min-h-screen flex flex-col items-center justify-center p-4 sm:p-8">

    <!-- 頂部標題區 -->
    <header class="w-full text-center py-6 mb-4">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Management Cloud</h1>
        <h2 class="text-xl text-gray-600">GeoTracer for IoV8</h2>
    </header>

    <!-- 主要應用程式框架 -->
    <main class="w-full max-w-[1200px] bg-white shadow-2xl rounded-xl overflow-hidden flex flex-col">
        
        <!-- 導覽列 (Navbar) -->
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-100 bg-white">
            <!-- Logo 區塊 -->
            <div class="flex items-center">
                <!-- Cablesoft SVG 標誌 -->
                <svg width="40" height="40" viewBox="0 0 100 100" class="mr-1">
                    <path d="M 65 20 A 35 35 0 1 0 65 80 L 52 67 A 17 17 0 1 1 52 33 Z" fill="#2563eb" />
                </svg>
                <span class="text-[28px] font-bold text-gray-900 tracking-tight">Cablesoft</span>
            </div>
            
            <!-- 購物車與通知圖示 -->
            <div class="relative cursor-pointer mr-2 mt-2">
                <i data-lucide="bell" class="w-8 h-8 text-gray-700 hover:text-blue-600 transition-colors"></i>
                <!-- 通知圓點 (確保字體至少 19px，因此外框調大) -->
                <span class="absolute -top-3 -right-4 bg-red-500 text-white w-7 h-7 flex items-center justify-center rounded-full leading-none font-bold shadow-sm">
                    0
                </span>
            </div>
        </div>

        <!-- 內容區 (漸層藍色背景) -->
        <div class="flex flex-col lg:flex-row bg-gradient-to-br from-brand-bg1 to-brand-bg2 min-h-[650px]">
            
            <!-- 左側：IoV 車聯網意象插圖 (使用 SVG 程式碼繪製抽象視覺) -->
            <div class="flex-1 p-8 hidden lg:flex items-center justify-center relative overflow-hidden">
                <svg viewBox="0 0 500 400" class="w-full h-full max-h-[500px]">
                    <!-- 等角透視群組 -->
                    <g transform="translate(250, 220) scale(1.3)">
                        <!-- 底部地圖板塊 -->
                        <polygon points="0,-90 140,-20 0,50 -140,-20" fill="#e0e7ff" opacity="0.9" stroke="#ffffff" stroke-width="3"/>
                        
                        <!-- 道路網格 -->
                        <polygon points="-70,-55 70,15 55,22 -85,-48" fill="#ffffff" opacity="0.7"/>
                        <polygon points="-40,-5 40,-45 55,-37 -25,3" fill="#ffffff" opacity="0.7"/>
                        
                        <!-- 懸浮儀表板/螢幕 (往左上微調) -->
                        <g transform="translate(-115, -165)">
                            <rect x="0" y="0" width="130" height="90" rx="8" fill="#1e3a8a" opacity="0.9"/>
                            <rect x="5" y="5" width="120" height="80" rx="4" fill="#f8fafc"/>
                            <!-- 螢幕內元素 -->
                            <rect x="15" y="15" width="50" height="30" rx="2" fill="#facc15"/>
                            <rect x="15" y="55" width="90" height="6" rx="3" fill="#cbd5e1"/>
                            <rect x="15" y="65" width="60" height="6" rx="3" fill="#cbd5e1"/>
                            <circle cx="95" cy="30" r="12" fill="#60a5fa"/>
                        </g>

                        <!-- 雲端元素 -->
                        <g transform="translate(100, -120)" fill="#ffffff" opacity="0.8">
                            <circle cx="0" cy="0" r="15"/>
                            <circle cx="15" cy="-10" r="20"/>
                            <circle cx="30" cy="0" r="15"/>
                            <rect x="0" y="-5" width="30" height="20"/>
                        </g>

                        <!-- 車輛 1 (黃色) -->
                        <g transform="translate(10, -15)">
                            <rect x="0" y="0" width="35" height="18" rx="4" fill="#f59e0b"/>
                            <rect x="6" y="-6" width="18" height="12" rx="2" fill="#ffffff" opacity="0.9"/>
                        </g>
                        
                        <!-- 車輛 2 (藍色) -->
                        <g transform="translate(-60, 25)">
                            <rect x="0" y="0" width="35" height="18" rx="4" fill="#3b82f6"/>
                            <rect x="6" y="-6" width="18" height="12" rx="2" fill="#ffffff" opacity="0.9"/>
                        </g>

                        <!-- 懸浮定位標記 Map Pin (往右下微調) -->
                        <g transform="translate(25, -50)">
                            <path d="M0,0 C-12,-18 -18,-30 -18,-42 A18,18 0 1,1 18,-42 C18,-30 12,-18 0,0 Z" fill="#3b82f6"/>
                            <circle cx="0" cy="-42" r="6" fill="#ffffff"/>
                        </g>
                    </g>
                </svg>
            </div>

            <!-- 右側：登入表單區塊 -->
            <div class="flex-1 p-6 sm:p-10 flex items-center justify-center">
                <div class="bg-white rounded-[24px] shadow-2xl p-8 sm:p-12 w-full max-w-[480px]">
                    
                    <!-- 卡片內部 Logo -->
                    <div class="flex items-center justify-center mb-10">
                        <svg width="45" height="45" viewBox="0 0 100 100" class="mr-2">
                            <path d="M 65 20 A 35 35 0 1 0 65 80 L 52 67 A 17 17 0 1 1 52 33 Z" fill="#2563eb" />
                        </svg>
                        <span class="text-[32px] font-bold text-gray-900 tracking-tight">Cablesoft</span>
                    </div>

                    <form onsubmit="event.preventDefault();" class="space-y-5">
                        <!-- 帳號輸入框 -->
                        <div class="relative">
                            <input type="text" placeholder="Username" 
                                class="w-full border border-gray-200 rounded-lg p-4 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                        </div>

                        <!-- 密碼輸入框 1 (帶有下拉圖示，如原圖設計) -->
                        <div class="relative">
                            <input type="password" placeholder="Password" 
                                class="w-full border border-gray-200 rounded-lg p-4 pr-12 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all appearance-none">
                            <i data-lucide="chevron-down" class="input-icon-right w-6 h-6"></i>
                        </div>

                        <!-- 密碼輸入框 2 (帶有鎖頭圖示，如原圖設計) -->
                        <div class="relative">
                            <i data-lucide="lock" class="input-icon-left w-6 h-6"></i>
                            <input type="password" placeholder="Password" 
                                class="w-full border border-gray-200 rounded-lg p-4 pl-12 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                        </div>

                        <!-- 驗證碼填寫框 -->
                        <div class="relative flex gap-3">
                            <input type="text" placeholder="驗證碼" 
                                class="w-full border border-gray-200 rounded-lg p-4 text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                            <!-- 模擬圖形驗證碼區域 -->
                            <div class="shrink-0 w-[120px] bg-[#e2e8f0] border border-gray-200 rounded-lg flex items-center justify-center font-bold text-gray-700 tracking-widest cursor-pointer hover:bg-gray-300 transition-colors select-none" title="點擊更換驗證碼">
                                8A4G
                            </div>
                        </div>

                        <!-- 記住我 與 忘記密碼 -->
                        <div class="flex items-center justify-between pt-1">
                            <label class="flex items-center cursor-pointer text-gray-600 hover:text-gray-900 transition-colors">
                                <input type="checkbox" class="w-6 h-6 accent-blue-600 cursor-pointer">
                                <span class="ml-2">記住我</span>
                            </label>
                            <a href="#" class="text-blue-600 hover:text-blue-800 font-medium transition-colors">忘記密碼？</a>
                        </div>

                        <!-- 隱私協議與服務條款 -->
                        <div class="flex items-start pb-2">
                            <label class="flex items-start cursor-pointer text-gray-600">
                                <input type="checkbox" class="w-6 h-6 mt-0.5 accent-blue-600 cursor-pointer shrink-0">
                                <span class="ml-2 leading-snug">
                                    我已閱讀並同意 
                                    <a href="#" class="text-blue-600 hover:underline font-medium">隱私協議</a> 
                                    和 
                                    <a href="#" class="text-blue-600 hover:underline font-medium">服務條款</a>。
                                </span>
                            </label>
                        </div>

                        <!-- 登入按鈕 -->
                        <button type="submit" 
                            class="w-full bg-[#3b6bd6] hover:bg-blue-700 text-white rounded-lg py-4 font-semibold mt-6 transition-colors shadow-md hover:shadow-lg">
                            Login
                        </button>
                    </form>

                </div>
            </div>
            
        </div>
    </main>

    <!-- 啟用 Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
